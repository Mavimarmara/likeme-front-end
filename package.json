{
  "name": "likeme-front-end",
  "version": "1.0.52",
  "description": "React Native app for health and wellness",
  "main": "index.js",
  "scripts": {
    "start": "npm run run:emulator:ios && npm run start:dev:tunnel",
    "start:clear": "expo start --clear",
    "start:reset": "expo start --clear --reset-cache",
    "start:tunnel": "npx expo start --reset-cache --clear --tunnel",
    "start:dev:tunnel": "npx expo start --dev-client --reset-cache --clear --tunnel",
    "start:staging": "env-cmd -f .env.staging npx expo start",
    "start:production": "env-cmd -f .env.production npx expo start",
    "start:local": "cp .env.local .env && npx expo start --reset-cache --clear --tunnel",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "android:clear": "expo start --clear --android",
    "ios": "expo run:ios",
    "ios:clear": "expo start --clear --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:update": "jest --updateSnapshot",
    "test:e2e": "~/.maestro/bin/maestro test maestro/",
    "test:e2e:welcome": "~/.maestro/bin/maestro test maestro/welcome-screen.yaml",
    "test:e2e:objectives": "~/.maestro/bin/maestro test maestro/personal-objectives.yaml",
    "test:e2e:onboarding": "~/.maestro/bin/maestro test maestro/onboarding-flow.yaml",
    "test:e2e:journey": "~/.maestro/bin/maestro test maestro/complete-user-journey.yaml",
    "test:e2e:expo-go": "./maestro/run-expo-go-tests.sh",
    "export:screenshots": "~/.maestro/bin/maestro test maestro/export-screenshots.yaml --test-output-dir=.maestro/screenshots",
    "export:screenshots:app": "~/.maestro/bin/maestro test maestro/export-screenshots-app.yaml --test-output-dir=.maestro/screenshots",
    "build": "npx tsc --noEmit && npm run lint",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "doctor": "npx expo-doctor",
    "assert:ios-apple-signin": "node scripts/assert-ios-apple-signin.cjs",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "build:android": "eas build --platform android --clear-cache",
    "build:android:local": "./build-android-local.sh",
    "sync:eas-secrets": "node scripts/sync-env-to-eas-secrets.js",
    "build:android:gradle": "npx expo prebuild --platform android && cd android && ./gradlew assembleRelease && cd ..",
    "build:android:production": "./build-android-production.sh",
    "build:android:apk": "./build-android-apk.sh",
    "build:ios": "eas build --platform ios --clear-cache",
    "build:ios:production-internal": "eas build --platform ios --profile production-internal --clear-cache",
    "build:ios:preview": "eas build --platform ios --profile preview --clear-cache",
    "build:ios:preview:skip-capability-sync": "EXPO_NO_CAPABILITY_SYNC=1 eas build --platform ios --profile preview --clear-cache",
    "build:ios:local": "./build-ios-local.sh",
    "build:ios:auto": "echo '3\ny' | ./build-ios-local.sh",
    "build:ios:simulator": "npx expo run:ios",
    "ios:xcode:clean-build": "cd ios && xcodebuild -workspace LikeMe.xcworkspace -scheme LikeMe -configuration Debug -sdk iphonesimulator clean build",
    "build:ios:device": "npx expo run:ios --device",
    "ios:run:device:production": "npx expo run:ios --device --configuration Production",
    "ios:run:device:production:no-bundler": "npx expo run:ios --device --configuration Production --no-bundler",
    "ios:run:device:release": "npx expo run:ios --device --configuration Release",
    "ios:run:device:release:no-bundler": "npx expo run:ios --device --configuration Release --no-bundler",
    "build:all": "eas build --platform all --clear-cache",
    "submit:android": "eas submit --platform android --latest --profile production",
    "submit:ios": "eas submit --platform ios",
    "submit:testflight": "./submit-to-testflight.sh",
    "run:apk": "./run-apk.sh",
    "run:emulator:android": "./start-emulator.sh",
    "install:apk": "./install-and-run-apk.sh",
    "clean": "rm -rf node_modules/.cache .expo dist android/build ios/build",
    "clean:all": "rm -rf node_modules/.cache .expo dist android/build ios/build android/app/build ios/Pods ios/Podfile.lock",
    "clean:android": "cd android && ./gradlew clean && cd ..",
    "clean:ios": "cd ios && rm -rf Pods Podfile.lock build && pod install && cd ..",
    "postinstall": "node scripts/patch-slider-podspec.js && node scripts/patch-rn-third-party-components-provider.js && if [ -d ios ] && [ -f ios/Podfile ] && [ \"$SKIP_IOS_POD_INSTALL\" != \"true\" ]; then cd ios && pod install && cd ..; fi",
    "run:emulator:ios": "open -a Simulator",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-native-firebase/analytics": "^23.8.5",
    "@react-native-firebase/app": "^23.8.5",
    "@react-native-firebase/messaging": "^23.8.5",
    "@react-native-firebase/remote-config": "^23.8.5",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-navigation-bar": "~5.0.10",
    "expo-splash-screen": "~31.0.13",
    "i18next": "^25.8.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.3",
    "react-native": "0.81.5",
    "react-native-auth0": "^5.1.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.11.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "^1.5.1",
    "react-native-vector-icons": "^10.0.2",
    "react-native-video": "^6.19.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "^0.81.0",
    "@react-native/eslint-config": "^0.81.0",
    "@react-native/metro-config": "^0.81.0",
    "@testing-library/react-native": "^13.3.3",
    "@tsconfig/react-native": "^3.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "~19.1.0",
    "babel-jest": "^29.2.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "dotenv": "^17.2.3",
    "env-cmd": "^11.0.0",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "~9.0.0",
    "husky": "^9.1.7",
    "jest": "^29.2.1",
    "lint-staged": "^16.2.7",
    "prettier": "^2.4.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "react-native",
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-vector-icons|react-native-video|expo|@expo|expo-auth-session|@react-navigation|@react-native-community)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@/assets/(.*)$": "<rootDir>/assets/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --no-error-on-unmatched-pattern",
      "prettier --write"
    ],
    "*.{spec,test}.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
