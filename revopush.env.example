# Copie para `.env` e preencha após criar os apps em https://app.revopush.org
#
# Setup (uma vez):
# 1. npx revopush login
# 2. npx revopush app add LikeMe-iOS
# 3. npx revopush app add LikeMe-Android
# 4. npx revopush deployment list LikeMe-iOS -k   → copie keys Staging / Production
# 5. npx revopush deployment list LikeMe-Android -k
# 6. EXCLUDE_EXPO_DEV_CLIENT=1 npm run native:prebuild:clean  (Production keys)
#    ou npm run native:prebuild:clean  (Staging keys)
#
# Release OTA (JS):
#   npm run revopush:release:ios -- Production "descricao"
#   npm run revopush:release:android -- Production "descricao"

REVOPUSH_APP_NAME_IOS=LikeMe-iOS
REVOPUSH_APP_NAME_ANDROID=LikeMe-Android

# Staging (dev client / builds internos)
REVOPUSH_DEPLOYMENT_KEY_IOS_STAGING=
REVOPUSH_DEPLOYMENT_KEY_ANDROID_STAGING=

# Production (loja)
REVOPUSH_DEPLOYMENT_KEY_IOS_PRODUCTION=
REVOPUSH_DEPLOYMENT_KEY_ANDROID_PRODUCTION=

# Fallback se não usar sufixo _STAGING / _PRODUCTION
# REVOPUSH_DEPLOYMENT_KEY_IOS=
# REVOPUSH_DEPLOYMENT_KEY_ANDROID=

# CI (GitHub Actions → Secrets): obrigatórios para OTA em builds de loja
# REVOPUSH_DEPLOYMENT_KEY_IOS_PRODUCTION
# REVOPUSH_DEPLOYMENT_KEY_ANDROID_PRODUCTION
